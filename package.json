{
  "name": "llm-logprob-dashboard",
  "version": "1.0.0",
  "description": "LLM Logprob Dashboard - OpenAI Responses APIを利用し、生成テキストの各トークンに対応するlog probabilityを取得・可視化する簡易分析ツール",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test tests/*.test.js",
    "cdk:synth": "cdk synth",
    "cdk:bootstrap": "cdk bootstrap",
    "cdk:deploy": "cdk deploy",
    "cdk:destroy": "cdk destroy"
  },
  "keywords": [
    "llm",
    "logprob",
    "openai",
    "dashboard",
    "visualization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "aws-cdk": "^2.1107.0",
    "aws-cdk-lib": "^2.240.0",
    "constructs": "^10.5.1"
  }
}
